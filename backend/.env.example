# monami voice backend — environment. Copy to backend/.env and fill in.
# backend/.env is GITIGNORED. Never commit real values.

# GCP project that has Vertex AI + Gemini Live enabled.
GOOGLE_CLOUD_PROJECT=your-gcp-project-id

# Region. Native-audio model is served ONLY in us-central1 (verified Phase 0).
GOOGLE_CLOUD_LOCATION=us-central1

# Native-audio model id (verified in Phase 0).
GEMINI_LIVE_MODEL=gemini-live-2.5-flash-native-audio

# Cheap TEXT model for end-of-session memory summaries (NOT the live model).
# Must be a current Vertex model served in your region.
MEMORY_SUMMARY_MODEL=gemini-2.5-flash

# Memory backend: "json" (local dev, default) or "firestore" (cloud).
# MEMORY_BACKEND=json

# Shared-secret token gating the WS. Unset = open (local dev only). In the cloud
# this MUST be set (as a Cloud Run secret) so strangers can't open a session.
# MONAMI_AUTH_TOKEN=change-me-to-a-long-random-string

# Optional: logging level (DEBUG | INFO | WARNING). Defaults to INFO.
# LOG_LEVEL=INFO

# Auth: this backend uses Application Default Credentials, NOT a key in this file.
# Run once on the machine:  gcloud auth application-default login
