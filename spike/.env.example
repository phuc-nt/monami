# Phase 0 spike config. Copy to spike/.env and fill in. NEVER commit the real .env.
#
# Auth: this harness uses Application Default Credentials (ADC), not an API key.
# Run once before using:  gcloud auth application-default login
# and ensure your account has Vertex AI access on the project below.

# Your GCP project id (Vertex AI + Gemini Live enabled, billing on).
GOOGLE_CLOUD_PROJECT=your-gcp-project-id

# Region for the Live native-audio model.
# VERIFIED 2026-06 via _probe_region.py: the native-audio model
# (gemini-live-2.5-flash-native-audio) is served ONLY in us-central1 —
# NOT asia-southeast1, NOT global. So we must use us-central1 even though it's
# farther from Vietnam (adds ~200-250ms RTT each way vs Singapore). Measuring
# whether that total latency is acceptable is part of the Phase 0 spike.
GOOGLE_CLOUD_LOCATION=us-central1

# === GEMINI LIVE MODEL ID — RESOLVE BEFORE RUNNING (Open Question #1) ===
# Do NOT trust a remembered/preview id. The preview model
# `gemini-live-2.5-flash-preview-native-audio-09-2025` was deprecated/removed
# on 2026-03-19.
#
# VERIFIED 2026-06: GA native-audio model id below connects successfully in
# us-central1 (tested live via _probe_region.py). Keep as-is unless Google
# renames it.
GEMINI_LIVE_MODEL=gemini-live-2.5-flash-native-audio
